# Kakao REST API Key (Used in server.ts for mobility features)
KAKAO_REST_API_KEY=

# Kakao JavaScript Key (Used in index.html for Kakao Maps)
# Prefix with NEXT_PUBLIC_ for client-side visibility
NEXT_PUBLIC_KAKAO_JS_KEY=

# Seoul Open Data API Key
SEOUL_API_KEY=

# Public Data Portal Bus API Key
BUS_API_KEY=

# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY=
